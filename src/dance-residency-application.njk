---
layout: layouts/page.njk
date: Last Modified
eleventyExcludeFromCollections: true
title: "Dance Residency Application"
description: "Apply for Nrityagram's Dance Residency which is a fully funded month-long residency for Indian classical dancers."
nobanner: true
---
<div class="container">
  <div class="wrapper flow">
    <h2 class="center">Apply for Dance Residency</h2>
    <section class="residency-form-section" id="apply">
      <div class="residency-form-container">

        <form id="residencyForm" novalidate>

          <!-- Name -->
          <div class="rf-group">
            <label for="rf-name">Name <span class="rf-required">•</span></label>
            <input type="text" id="rf-name" name="name" required>
          </div>

          <!-- Email -->
          <div class="rf-group">
            <label for="rf-email">Email <span class="rf-required">•</span></label>
            <input type="email" id="rf-email" name="email" required>
          </div>

          <!-- Individual / Duo / Group -->
          <div class="rf-group">
            <label>Are you applying as an individual or a group? <span class="rf-required">•</span></label>
            <div class="rf-pill-options">
              <label class="rf-pill">
                <input type="radio" name="applicationType" value="Individual" required>
                <span class="rf-pill-label">
                  <span class="rf-pill-icon">A</span> Individual</span>
              </label>
              <label class="rf-pill">
                <input type="radio" name="applicationType" value="Duo">
                <span class="rf-pill-label">
                  <span class="rf-pill-icon">B</span> Duo</span>
              </label>
              <label class="rf-pill">
                <input type="radio" name="applicationType" value="Group">
                <span class="rf-pill-label">
                  <span class="rf-pill-icon">C</span> Group (3 or more)</span>
              </label>
            </div>
          </div>

          <!-- Artiste Bio -->
          <div class="rf-group">
            <label for="rf-bio">Artiste Bio ( 100 words max) <span class="rf-required">•</span></label>
            <textarea id="rf-bio" name="artisteBio" required rows="5" maxlength="700"></textarea>
          </div>

          <!-- Resume Upload -->
          <div class="rf-group">
            <label>Resume <span class="rf-required">•</span></label>
            <div class="rf-file-upload" id="rfDropZone">
              <input type="file" id="rf-resume" name="resume" accept=".pdf" required>
              <div class="rf-file-upload-content">
                <span class="rf-upload-icon">&#8682;</span>
                <span class="rf-upload-text">Click to choose a file or drag here</span>
                <span class="rf-upload-meta">Accepts .pdf files</span>
                <span class="rf-upload-meta">Size limit: 10 MB</span>
              </div>
              <div class="rf-file-chosen" id="rfFileChosen" style="display:none;">
                <span class="rf-file-name" id="rfFileName"></span>
                <button type="button" class="rf-file-remove" id="rfFileRemove">&times;</button>
              </div>
            </div>
          </div>

          <!-- Work Samples -->
          <div class="rf-group">
            <label for="rf-samples">Work Samples:<br />
              <span class="desc">Share a link of your work (Google Drive, Dropbox, YouTube, Vimeo, etc.)</span>
            </label>
            <input type="url" id="rf-samples" name="workSamples">
          </div>

          <!-- Preferred Slot -->
          <div class="rf-group">
            <label for="rf-slot">Preferred slot:<br />
              <span class="desc">The residency will run between August 1 - September, 2026 and Jan 03 - March 31, 2027. Please let us know you preferred selection of 4 weeks or two 2 week slots between these dates.</span>
            </label>
            <input type="text" id="rf-slot" name="preferredSlot">
          </div>

          <!-- Preferred Accommodation -->
          <div class="rf-group">
            <label>Preferred accommodation:</label>
            <div class="rf-radio-group">
              <label class="rf-radio">
                <input type="radio" name="accommodation" value="Single">
                <span class="rf-radio-mark"></span>
                <span class="rf-radio-label">Single occupancy</span>
              </label>
              <label class="rf-radio">
                <input type="radio" name="accommodation" value="Double">
                <span class="rf-radio-mark"></span>
                <span class="rf-radio-label">Double occupancy (shared with another resident)</span>
              </label>
            </div>
          </div>

          <!-- Allergies -->
          <div class="rf-group">
            <label for="rf-allergies">Do you have any allergies to food or anything else? If yes, provide details. <span class="rf-required">•</span></label>
            <textarea id="rf-allergies" name="allergies" required rows="4"></textarea>
          </div>

          <!-- Health Conditions -->
          <div class="rf-group">
            <label for="rf-health">Do you have any health conditions or accessibility needs we should be aware of? If yes, provide details. <span class="rf-required">•</span></label>
            <textarea id="rf-health" name="healthConditions" required rows="4"></textarea>
          </div>

          <!-- Submit -->
          <div class="rf-group rf-submit-row">
            <button type="submit" id="rfSubmitBtn" class="rf-submit-btn">
                SUBMIT
              </button>
            <div id="rfFormStatus" class="rf-status" aria-live="polite"></div>
          </div>

          <p class="small-text">
            <a href="/dance-residency" class="bodylink">Back to Dance Residency</a>
          </p>

        </form>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
     JAVASCRIPT — Form Submission Handler
     ═══════════════════════════════════════════════════════════ -->
    <script>
      (function () {
        // ⚠️ REPLACE THIS with your deployed Google Apps Script URL
        var SCRIPT_URL = "https://script.google.com/macros/s/AKfycbw_xL1OEo4i34Ma76Yjfp5ah7vQvFwD0VAkgAfKMlMUWiKCGe4uMFr-4RqTFNVOfTslxw/exec";

        var form = document.getElementById("residencyForm");
        var submitBtn = document.getElementById("rfSubmitBtn");
        var statusEl = document.getElementById("rfFormStatus");
        var fileInput = document.getElementById("rf-resume");
        var dropZone = document.getElementById("rfDropZone");
        var fileChosen = document.getElementById("rfFileChosen");
        var fileNameEl = document.getElementById("rfFileName");
        var fileRemoveBtn = document.getElementById("rfFileRemove");

        // ── Drag & drop + file selection UI ─────────────────────
        fileInput.addEventListener("change", function () {
          if (fileInput.files.length > 0) {
            showFile(fileInput.files[0]);
          }
        });

        dropZone.addEventListener("dragover", function (e) {
          e.preventDefault();
          dropZone
            .classList
            .add("rf-dragover");
        });

        dropZone.addEventListener("dragleave", function () {
          dropZone
            .classList
            .remove("rf-dragover");
        });

        dropZone.addEventListener("drop", function (e) {
          e.preventDefault();
          dropZone
            .classList
            .remove("rf-dragover");
          if (e.dataTransfer.files.length > 0) {
            fileInput.files = e.dataTransfer.files;
            showFile(e.dataTransfer.files[0]);
          }
        });

        fileRemoveBtn.addEventListener("click", function () {
          fileInput.value = "";
          fileChosen.style.display = "none";
          dropZone
            .querySelector(".rf-file-upload-content")
            .style
            .display = "";
        });

        function showFile(file) {
          fileNameEl.textContent = file.name + " (" + (
          file.size / 1024 / 1024).toFixed(1) + " MB)";
          fileChosen.style.display = "flex";
          dropZone
            .querySelector(".rf-file-upload-content")
            .style
            .display = "none";
        }

        // ── Form submission ─────────────────────────────────────
        form.addEventListener("submit", async function (e) {
          e.preventDefault();

          if (!form.checkValidity()) {
            form.reportValidity();
            return;
          }

          // File size check (10MB)
          if (fileInput.files.length > 0 && fileInput.files[0].size > 10 * 1024 * 1024) {
            statusEl.textContent = "File size must be under 10 MB.";
            statusEl.className = "rf-status rf-error";
            return;
          }

          submitBtn.disabled = true;
          submitBtn.innerHTML = 'Submitting\u2026';
          statusEl.textContent = "";
          statusEl.className = "rf-status";

          try {
            var payload = {};
            payload.name = form.name.value;
            payload.email = form.email.value;
            payload.applicationType = form.applicationType
              ? form.applicationType.value
              : "";
            payload.artisteBio = form.artisteBio.value;
            payload.workSamples = form.workSamples.value;
            payload.preferredSlot = form.preferredSlot.value;
            payload.allergies = form.allergies.value;
            payload.healthConditions = form.healthConditions.value;

            // Collect accommodation radio
            var accRadio = form.querySelector('input[name="accommodation"]:checked');
            payload.accommodation = accRadio
              ? accRadio.value
              : "";

            // File as base64
            if (fileInput.files.length > 0) {
              var base64 = await readFileAsBase64(fileInput.files[0]);
              payload.fileData = base64;
              payload.fileName = fileInput
                .files[0]
                .name;
              payload.fileMimeType = fileInput
                .files[0]
                .type;
            }

            await fetch(SCRIPT_URL, {
              method: "POST",
              mode: "no-cors",
              headers: {
                "Content-Type": "application/x-www-form-urlencoded"
              },
              body: new URLSearchParams(payload).toString()
            });

            statusEl.innerHTML = "Thank you! Your application has been submitted successfully. " + "We will review it and get back to you at the email address you provided.";
            statusEl.className = "rf-status rf-success";
            form.reset();
            fileChosen.style.display = "none";
            dropZone
              .querySelector(".rf-file-upload-content")
              .style
              .display = "";

          } catch (error) {
            statusEl.textContent = "Something went wrong. Please try again or email us at programmes@nrityagram.org";
            statusEl.className = "rf-status rf-error";
          } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = 'SUBMIT';
          }
        });

        function readFileAsBase64(file) {
          return new Promise(function (resolve, reject) {
            var reader = new FileReader();
            reader.onload = function () {
              resolve(reader.result.split(",")[1]);
            };
            reader.onerror = reject;
            reader.readAsDataURL(file);
          });
        }
      })();
    </script>
  </div>
</div>