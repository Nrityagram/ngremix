    </div>

    {# To add more CTAs: copy a cta-mobile div above and update content and href #}
    <div class="cta-mobile-dots"></div>
</div>

<script>
    (function () {
        var container = document.currentScript.previousElementSibling;
        var items = Array.from(container.querySelectorAll('.cta-mobile'));
        if (items.length <= 1) {
            if (items.length === 1) {
                var progressEl = container.querySelector('.cta-mobile-progress');
                progressEl.style.display = 'none';
            }
            return;
        }

        var current = 0;
        var displayDuration = 7500;

        // Build dots
        var dotsEl = container.querySelector('.cta-mobile-dots');
        items.forEach(function (_, i) {
            var dot = document.createElement('button');
            dot.className = 'cta-mobile-dot' + (
                i === 0
                ? ' cta-mobile-dot--active'
                : '');
            dot.setAttribute('aria-label', 'Go to announcement ' + (
            i + 1));
            (function (idx) {
                dot.addEventListener('click', function (e) {
                    e.stopPropagation();
                    show(idx);
                    resetProgress();
                });
            })(i);
            dotsEl.appendChild(dot);
        });

        // Show only the first CTA; hide the rest
        items.forEach(function (el, i) {
            if (i !== 0) 
                el.style.display = 'none';
            }
        );

        var progressEl = container.querySelector('.cta-mobile-progress');

        function resetProgress() {
            progressEl.style.animation = 'none';
            progressEl.offsetWidth; // force reflow
            progressEl.style.animation = '';
        }

        function show(index) {
            items.forEach(function (el, i) {
                el.style.display = (i === index)
                    ? 'grid'
                    : 'none';
            });
            var dots = dotsEl.querySelectorAll('.cta-mobile-dot');
            dots.forEach(function (dot, i) {
                dot
                    .classList
                    .toggle('cta-mobile-dot--active', i === index);
            });
            current = index;
            resetProgress();
        }

        function advance() {
            show((current + 1) % items.length);
            setTimeout(advance, displayDuration);
        }

        setTimeout(advance, displayDuration);
    })();
</script>