<div class="cta-mobile-container">
    <div class="cta-mobile"
             onclick="location.href='/summer-fun-for-kids';">
        <div class="cta-line-lrg">
            <span class="whitetext">Summer Fun for Kids</span>
        </div>
        <div class="cta-line-sml">28 April - 3 May 2026 • Registrations Open</div>
        <div class="cta-arrow"><img src="/img/cta-arrow-circle-right.svg" alt=""></div>
    </div>

    <div class="cta-mobile"
             onclick="location.href='/dance-residency';">
        <div class="cta-line-lrg">
            <span class="whitetext">Fully-funded Dance Residency</span>
        </div>
        <div class="cta-line-sml">Deadline: 15 May 2026 • Applications Open</div>
        <div class="cta-arrow"><img src="/img/cta-arrow-circle-right.svg" alt=""></div>
    </div>

    {# To add more CTAs: copy a cta-mobile div above and update content and href #}
</div>

<script>
    (function () {
        var container = document.currentScript.previousElementSibling;
        var items = Array.from(container.querySelectorAll('.cta-mobile'));
        if (items.length <= 1) return;

        var current = 0;
        var displayDuration = 5000;

        // Show only the first CTA; hide the rest
        items.forEach(function (el, i) {
            if (i !== 0) el.style.display = 'none';
        });

        function show(index) {
            items.forEach(function (el, i) {
                el.style.display = (i === index) ? 'grid' : 'none';
            });
            current = index;
        }

        function advance() {
            show((current + 1) % items.length);
            setTimeout(advance, displayDuration);
        }

        setTimeout(advance, displayDuration);
    })();
</script>