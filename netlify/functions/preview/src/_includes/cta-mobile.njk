<script>
    (function () {
        var container = document.currentScript.previousElementSibling;
        var items = Array.from(container.querySelectorAll('.cta-mobile'));

        if (items.length === 0) {
            container.style.display = 'none';
            return;
        }

        if (items.length === 1) {
            container
                .querySelectorAll('.cta-nav-prev, .cta-nav-next')
                .forEach(function (btn) {
                    btn.style.display = 'none';
                });
            return;
        }

        var current = 0;
        var displayDuration = 7500;
        var advanceTimer = null;

        // Wire up prev/next chevrons
        container
            .querySelectorAll('.cta-nav-prev')
            .forEach(function (btn) {
                btn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    show((current - 1 + items.length) % items.length);
                    scheduleAdvance();
                });
            });
        container
            .querySelectorAll('.cta-nav-next')
            .forEach(function (btn) {
                btn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    show((current + 1) % items.length);
                    scheduleAdvance();
                });
            });

        // Show only the first CTA; hide the rest
        items.forEach(function (el, i) {
            if (i !== 0) 
                el.style.display = 'none';
            }
        );

        function startProgress(index) {
            var fill = items[index].querySelector('.cta-progress-fill');
            if (!fill) 
                return;
            fill.style.animation = 'none';
            fill.offsetHeight; // force reflow to restart animation
            fill.style.animation = 'cta-progress ' + displayDuration + 'ms linear forwards';
        }

        function show(index) {
            items.forEach(function (el, i) {
                el.style.display = (i === index)
                    ? 'grid'
                    : 'none';
            });
            current = index;
            startProgress(index);
        }

        function scheduleAdvance() {
            clearTimeout(advanceTimer);
            advanceTimer = setTimeout(function () {
                show((current + 1) % items.length);
                scheduleAdvance();
            }, displayDuration);
        }

        startProgress(0);
        scheduleAdvance();
    })();
</script>